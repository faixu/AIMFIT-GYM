{
  "entities": {
    "video": {
      "title": "Video",
      "description": "Metadata for a video in the gallery.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the video."
        },
        "description": {
          "type": "string",
          "description": "A short description of the video."
        },
        "url": {
          "type": "string",
          "description": "The URL of the video file in Firebase Storage."
        },
        "thumbnailUrl": {
          "type": "string",
          "description": "The URL of the video thumbnail."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the video was uploaded."
        },
        "authorUid": {
          "type": "string",
          "description": "The UID of the admin who uploaded the video."
        }
      },
      "required": ["title", "url", "createdAt", "authorUid"]
    },
    "user": {
      "title": "User",
      "description": "User profile data.",
      "type": "object",
      "properties": {
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "description": "The user's email address."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"],
          "description": "The user's role (admin or user)."
        }
      },
      "required": ["displayName", "email", "role"]
    }
  },
  "firestore": {
    "/videos/{videoId}": {
      "schema": "video",
      "description": "Collection of videos."
    },
    "/users/{userId}": {
      "schema": "user",
      "description": "Collection of user profiles."
    },
    "/gallery/{id}": {
      "schema": "object",
      "description": "Gallery images."
    },
    "/trainers/{id}": {
      "schema": "object",
      "description": "Trainer profiles."
    },
    "/pricing/{id}": {
      "schema": "object",
      "description": "Pricing plans."
    },
    "/contact/{id}": {
      "schema": "object",
      "description": "Contact information."
    },
    "/settings/{id}": {
      "schema": "object",
      "description": "Site settings."
    },
    "/supplements/{id}": {
      "schema": "object",
      "description": "Supplements."
    },
    "/orders/{id}": {
      "schema": "object",
      "description": "Customer orders."
    }
  }
}
