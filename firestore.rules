rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: videos
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - description: string (optional)
    //   - url: string (required, URL)
    //   - thumbnailUrl: string (optional, URL)
    //   - createdAt: timestamp (required)
    //   - authorUid: string (required)
    //
    // Collection: users
    // Document ID: userId (UID)
    // Fields:
    //   - displayName: string (required)
    //   - email: string (required)
    //   - role: string (required, 'admin' or 'user')
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "faisal.hassan.0996@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidVideo(data) {
      return data.keys().hasAll(['title', 'url', 'createdAt', 'authorUid']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.url is string && data.url.matches("^https?://.*") &&
             data.authorUid == request.auth.uid;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'email', 'role']) &&
             data.displayName is string && data.displayName.size() > 0 &&
             data.email is string && data.role in ['admin', 'user'];
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'user' || isAdmin());
      allow update: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /videos/{videoId} {
      allow read: if true; // Publicly readable gallery
      allow create: if isAdmin() && isValidVideo(request.resource.data);
      allow update: if isAdmin() && isValidVideo(request.resource.data) && request.resource.data.authorUid == resource.data.authorUid;
      allow delete: if isAdmin() && resource.data.authorUid == request.auth.uid;
    }

    match /gallery/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /trainers/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /pricing/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /contact/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /supplements/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{id} {
      allow create: if true; // Allow anyone to place an order
      allow read, write: if isAdmin();
    }

    match /test/{id} {
      allow read: if true;
    }
  }
}
